# Токен Telegram-бота от @BotFather
BOT_TOKEN=

# Ключ OpenAI API: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Твой Telegram ID (узнать у @userinfobot). Несколько — через запятую.
# Пусто = доступ открыт ВСЕМ (не рекомендуется).
OWNER_IDS=

# Модель по умолчанию для новых пользователей.
# Формат, качество и модель каждый пользователь меняет прямо в боте через /settings.
#   OPENAI_MODEL: gpt-image-2 | gpt-image-1.5 | gpt-image-1 | gpt-image-1-mini
OPENAI_MODEL=gpt-image-2

# Путь к базе SQLite
DB_PATH=data/imagebot.db
